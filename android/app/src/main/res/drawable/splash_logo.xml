<?xml version="1.0" encoding="utf-8"?>
<!-- Placeholder splash screen logo -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <!-- Background circle -->
    <path
        android:fillColor="#4CAF50"
        android:pathData="M100,100m-80,0a80,80 0,1 1,160 0a80,80 0,1 1,-160 0"/>
    <!-- Music note icon -->
    <group
        android:translateX="100"
        android:translateY="100">
        <!-- Note head -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M-20,-20 L-20,20 L20,20 L20,-20 Z"/>
        <!-- Note stem -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M20,20 L20,60 L15,60 L15,20 Z"/>
    </group>
</vector>






